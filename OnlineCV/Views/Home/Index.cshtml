@{
    ViewData["Title"] = "Home";
}

<style>
    /* General body styling */
    body {
        background-color: #f8f9fa;
        font-family: 'Poppins', sans-serif;
    }

    /* Container styling for central alignment and aesthetics */
    .container {
        max-width: 900px;
        background: #ffffff;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1);
    }

    /* Heading styling */
    h1, h2, h4 {
        color: #333;
    }

    /* Muted text for subtle contrast */
    .text-muted {
        color: #6c757d !important;
    }

    /* Styling for contact links */
    .contact-info a {
        text-decoration: none;
        color: #007bff;
    }
    .contact-info a:hover {
        text-decoration: underline;
    }

    /* Sections with spacing */
    section {
        margin-bottom: 30px;
    }

    /* Styling for links */
    a {
        color: #007bff;
        text-decoration: none;
    }
    a:hover {
        text-decoration: underline;
    }

    /* Styling for experience, education, technical skills, and project cards */
    .experience-item, .education-item, .project-item, .skills-item {
        background: #f0f4f8;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 10px;
    }
</style>

